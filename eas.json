{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://uatmobileapi.adsmartsupport.ae/SmartSCADMobileAPI/api/v1"
      }
    },
    "uat": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://uatmobileapi.adsmartsupport.ae/SmartSCADMobileAPI/api/v1"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mobileapi.adsmartsupport.ae/SmartSCADMobileAPI/api/v1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "apps@scad.ae"
      }
    }
  }
}
