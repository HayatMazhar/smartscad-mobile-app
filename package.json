{
  "name": "smartscad-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "start:metro": "react-native start",
    "web": "webpack serve --config webpack.config.js",
    "web:build": "webpack --config webpack.config.js --mode production",
    "lint": "eslint .",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "apk:dev:install": "cd android && gradlew.bat installDebug -PreactNativeArchitectures=arm64-v8a",
    "apk:dev": "cd android && gradlew.bat assembleDebug -PreactNativeArchitectures=arm64-v8a",
    "apk:release": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "apk:release:install": "cd android && gradlew.bat installRelease -PreactNativeArchitectures=arm64-v8a",
    "apk:clean": "cd android && gradlew.bat clean",
    "android:devices": "%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe devices",
    "e2e:install-maestro": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-maestro.ps1",
    "e2e": "scripts\\maestro.cmd test .maestro/flows",
    "e2e:studio": "scripts\\maestro.cmd studio",
    "ios:build:uat": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 -Platform ios -Profile uat",
    "ios:build:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 -Platform ios -Profile production",
    "android:build:uat": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 -Platform android -Profile uat",
    "android:build:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 -Platform android -Profile production"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@reduxjs/toolkit": "^2.5.0",
    "dayjs": "^1.11.0",
    "expo": "55.0.17",
    "expo-application": "~55.0.14",
    "expo-build-properties": "~0.13.2",
    "expo-crypto": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "i18next": "^24.2.0",
    "process": "^0.11.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.4.0",
    "react-native": "0.83.6",
    "react-native-blob-util": "~0.21.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^3.3.0",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "~0.8.1",
    "react-redux": "^9.2.0"
  },
  "overrides": {
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.0.0",
    "@react-native/babel-preset": "0.83.6",
    "@react-native/eslint-config": "0.83.6",
    "@react-native/metro-config": "0.83.6",
    "@react-native/typescript-config": "0.83.6",
    "@types/react": "~19.2.10",
    "@types/react-native-vector-icons": "^6.4.0",
    "babel-loader": "^10.1.1",
    "babel-preset-expo": "~55.0.18",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.57.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.7.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.3.0",
    "typescript": "~5.9.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
