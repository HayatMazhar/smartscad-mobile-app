{
  "expo": {
    "name": "Sanadkom",
    "slug": "smartscad-mobile",
    "scheme": "smartscadmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/sanadkom_apk_icon_composite.png",
    "ios": {
      "bundleIdentifier": "ae.adsmartsupport.smartscadmobile",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "uatmobileapi.adsmartsupport.ae": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            },
            "mobileapi.adsmartsupport.ae": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            },
            "adsmartsupport.ae": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mazhar1785.smartscadmobile",
      "versionCode": 1
    },
    "plugins": [
      "./plugins/with-pods-deployment-target",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "extraPods": [
              {
                "name": "react-native-mmkv",
                "configurations": ["Debug", "Release"],
                "xcconfig": {
                  "OTHER_LDFLAGS": "$(inherited) -lz"
                }
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "92dfdfd9-6beb-4d7a-a9c8-503c19c81d1f"
      }
    },
    "owner": "mazhar1785"
  }
}
